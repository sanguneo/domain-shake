{
  "name": "domain-shake",
  "version": "1.1.0",
  "description": "A tiny pair of browser modules that establish a trusted communication channel between two independent windows.",
  "type": "module",
  "main": "js/index.js",
  "module": "js/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./js/index.js"
    },
    "./peerInitiator": {
      "types": "./types/peerInitiator.d.ts",
      "import": "./js/peerInitiator.js"
    },
    "./peerResponder": {
      "types": "./types/peerResponder.d.ts",
      "import": "./js/peerResponder.js"
    },
    "./dshake.types": {
      "types": "./types/dshake.types.d.ts",
      "import": "./js/dshake.types.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "js",
    "ts",
    "types",
    "scripts",
    "README.md",
    "README.ko.md"
  ],
  "dependencies": {},
  "devDependencies": {
    "esbuild": "^0.25.11",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "node scripts/build.mjs && tsc -p tsconfig.build.json",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanguneo/domain-shake.git"
  },
  "keywords": [
    "domain",
    "handshake",
    "postmessage",
    "typescript",
    "javascript"
  ],
  "author": "sanguneo <iam@sanguneo.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sanguneo/domain-shake/issues"
  },
  "homepage": "https://github.com/sanguneo/domain-shake#readme"
}
